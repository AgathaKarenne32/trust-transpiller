<?xml version="1.0" encoding="UTF-8"?>
<!--
  pom.xml — Trust-Transpiler
  
  IMPORTANTE: Este pom.xml é apenas um DESCRITOR DO PROJETO.
  Ele NÃO declara dependências externas (como org.rascalmpl:rascal)
  porque o nexus.usethesource.io possui um certificado SSL inválido
  que impede o download em ambientes CI/CD padrão.
  
  O rascal-shell-stable.jar é um "fat JAR" auto-suficiente:
  inclui o interpretador + stdlib completa.
  Ele é baixado diretamente via curl no workflow.
-->
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0
                             http://maven.apache.org/xsd/maven-4.0.0.xsd">
  <modelVersion>4.0.0</modelVersion>

  <groupId>org.trust-transpiler</groupId>
  <artifactId>trust-transpiler</artifactId>
  <version>0.1.0</version>
  <packaging>jar</packaging>

  <name>Trust-Transpiler</name>
  <description>Universal Static Security Auditor — Taint Analysis in Rascal MPL</description>

  <properties>
    <maven.compiler.source>17</maven.compiler.source>
    <maven.compiler.target>17</maven.compiler.target>
    <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
  </properties>

  <!-- Sem dependências externas -->
  <dependencies/>

  <build>
    <sourceDirectory>src</sourceDirectory>
    <resources>
      <resource>
        <directory>src</directory>
        <includes>
          <include>**/*.rsc</include>
        </includes>
      </resource>
      <resource>
        <!-- Garante que META-INF/RASCAL.MF seja copiado para target/classes/META-INF/ -->
        <directory>${project.basedir}</directory>
        <includes>
          <include>META-INF/RASCAL.MF</include>
        </includes>
      </resource>
    </resources>
  </build>
</project>
